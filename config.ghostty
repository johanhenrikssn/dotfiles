# Ghostty Configuration
# Reload: Cmd+Shift+,

# Font
font-family = Fira Code
font-size = 14
font-thicken = true

# Theme
background-opacity = 1

# Window
window-padding-x = 8
window-padding-y = 4
window-padding-balance = true
macos-titlebar-style = tabs
macos-window-shadow = true

# Cursor
cursor-style = block
cursor-style-blink = false

# macOS (left Option=Alt, right Option for special chars like @ {})
macos-option-as-alt = left

# Global hotkey to show/hide all windows
keybind = global:§=toggle_visibility

# Scrollback (10x default for Claude Code output, allocated lazily)
scrollback-limit = 100000000

# Split panes
unfocused-split-opacity = 0.7

# New windows/tabs/splits inherit working directory
window-inherit-working-directory = true

# Shell
shell-integration-features = cursor,sudo,no-title
mouse-hide-while-typing = true
